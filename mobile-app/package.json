{
  "name": "mobile-app",
  "version": "1.0.0",
  "main": "index.js",
  "private": true,
  "expo": {
    "doctor": {
      "reactNativeDirectoryCheck": {
        "listUnknownPackages": false,
        "exclude": [
          "react-native-maps",
          "react-native-star-rating-widget",
          "react-native-segmented-control-tab"
        ]
      }
    }
  },
  "scripts": {
    "start": "node node_modules/expo/bin/cli start",
    "android": "node node_modules/expo/bin/cli run:android",
    "android:dev": "node node_modules/expo/bin/cli start --dev-client",
    "android:logs": "bash scripts/android-logs.sh",
    "ios": "node node_modules/expo/bin/cli run:ios",
    "clear": "node node_modules/expo/bin/cli start --clear",
    "eject": "node node_modules/expo/bin/cli eject",
    "update": "node node_modules/expo/bin/cli update",
    "postinstall": "node scripts/fix-firebase-kotlin.js || true",
    "test:e2e": "maestro test .maestro/flows",
    "test:e2e:auth": "maestro test .maestro/flows/auth",
    "test:e2e:rides": "maestro test .maestro/flows/rides",
    "test:e2e:payments": "maestro test .maestro/flows/payments",
    "test:e2e:driver": "maestro test .maestro/flows/driver",
    "test:e2e:debug": "maestro test .maestro/flows --debug",
    "test:e2e:view": "bash scripts/view-test-results.sh",
    "test:e2e:live": "bash scripts/run-test-live.sh",
    "test:e2e:device": "bash scripts/run-test-device.sh",
    "test:device": "bash scripts/test-device-simple.sh",
    "device:connect": "bash scripts/connect-device.sh",
    "reverse": "adb reverse tcp:3001 tcp:3001 && adb reverse tcp:8081 tcp:8081",
    "emulator:setup": "bash scripts/setup-emulator.sh",
    "test:e2e:vps": "bash scripts/run-e2e-vps.sh",
    "test:e2e:stable": "bash scripts/run-e2e-stable-guarded.sh",
    "test:e2e:appium": "node e2e-appium/run-leaf-e2e.cjs",
    "test:e2e:adb": "node e2e-adb/run-leaf-e2e-adb.cjs"
  },
