# Configuração do Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# Feature Flags para Estratégia Híbrida Otimizada
ENABLE_REDIS=true
REDIS_PRIMARY=true
FIREBASE_FALLBACK=true
FIRESTORE_PERSISTENCE=true
DUAL_WRITE=false
AUTO_MIGRATE=true
USE_GEO_COMMANDS=true

# Configurações de Desenvolvimento
NODE_ENV=development
DEBUG=true 