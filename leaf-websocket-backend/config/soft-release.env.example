# Soft release profile (HTTP + Socket rate limits)
# Copy required keys to your runtime environment (VPS, Docker env, etc.)

# HTTP limiter (middleware/rateLimiter.js)
RATE_LIMIT_HTTP_GENERAL_WINDOW_SECONDS=60
RATE_LIMIT_HTTP_GENERAL=200
RATE_LIMIT_HTTP_AUTH_WINDOW_SECONDS=900
RATE_LIMIT_HTTP_AUTH=8
RATE_LIMIT_HTTP_LOCATION_WINDOW_SECONDS=60
RATE_LIMIT_HTTP_LOCATION=240
RATE_LIMIT_HTTP_WEBSOCKET_WINDOW_SECONDS=60
RATE_LIMIT_HTTP_WEBSOCKET=220
RATE_LIMIT_HTTP_PAYMENT_WINDOW_SECONDS=60
RATE_LIMIT_HTTP_PAYMENT=80

# Socket limiter (services/rate-limiter-service.js)
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_FLOW_CORE=80
RATE_LIMIT_CREATE_BOOKING=80
RATE_LIMIT_CONFIRM_PAYMENT=80
RATE_LIMIT_START_TRIP=80
RATE_LIMIT_FINISH_TRIP=80
RATE_LIMIT_ACCEPT_RIDE=120
RATE_LIMIT_CANCEL_RIDE=20
RATE_LIMIT_REJECT_RIDE=240
RATE_LIMIT_UPDATE_LOCATION=2400
RATE_LIMIT_UPDATE_DRIVER_LOCATION=3000
RATE_LIMIT_SEARCH_DRIVERS=600
RATE_LIMIT_SEND_MESSAGE=180

# Woovi environment split
# Use sandbox in homolog/test and production in live environment.
WOOVI_ENVIRONMENT=sandbox
WOOVI_BASE_URL=https://api.woovi-sandbox.com/api/v1
# Production example:
# WOOVI_ENVIRONMENT=production
# WOOVI_BASE_URL=https://api.woovi.com/api/v1

# Security & observability hints
CORS_ORIGIN=https://app.leaf.example,https://dashboard.leaf.example
ALLOW_PRIVATE_CORS=false
ALLOW_NGROK_CORS=false
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318/v1/traces

# KYC device-first (release hardening)
# Keep heavy face processing on device and lightweight validation on backend.
KYC_SIMILARITY_THRESHOLD=0.5
# Keep false in soft-release to avoid per-request heavy writes/logs.
KYC_WRITE_AUDIT_KEY=false
KYC_LOG_SUCCESS_VERBOSE=false
