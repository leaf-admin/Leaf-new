{
  "name": "leaf-websocket-backend",
  "version": "1.0.0",
  "description": "WebSocket backend para LEAF com Redis e Firebase",
  "main": "server.js",
  "engines": {
    "node": ">=20.19.0"
  },
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "npm run test:unit && npm run test:integration",
    "test:all": "npm run test:unit && npm run test:integration && npm run test:e2e",
    "test:unit": "npx jest --config config/jest.unit.config.js",
    "test:unit:watch": "npx jest --config config/jest.unit.config.js --watch",
    "test:unit:coverage": "npx jest --config config/jest.unit.config.js --coverage",
    "test:integration": "npx jest --config config/jest.integration.config.js",
    "test:integration:watch": "npx jest --config config/jest.integration.config.js --watch",
    "test:integration:coverage": "npx jest --config config/jest.integration.config.js --coverage",
    "test:e2e": "npx jest --config config/jest.config.js",
    "test:e2e:watch": "npx jest --config config/jest.config.js --watch",
    "test:e2e:coverage": "npx jest --config config/jest.config.js --coverage",
    "test:e2e:passenger": "npx jest --config config/jest.config.js tests/e2e/backend/flows/passenger-flow.test.js",
    "test:e2e:driver": "npx jest --config config/jest.config.js tests/e2e/backend/flows/driver-flow.test.js",
    "test:basic": "node test-integration.js",
    "test:architecture": "node test-architecture.js",
    "test:multiple-drivers": "node test-multiple-drivers.js",
    "test:optimizations": "node scripts/tests/test-optimizations.js",
    "benchmark": "node scripts/benchmark/performance-benchmark.js",
    "stress-test": "node scripts/benchmark/stress-test.js",
    "admin:create": "node scripts/create-admin-user.js",
    "admin:test": "node test-admin-auth.js",
    "ngrok:start": "node scripts/utils/start-ngrok.js",
    "ngrok:auto": "node scripts/utils/start-ngrok-auto.js",
    "ngrok:url": "node scripts/utils/get-ngrok-url.js"
  },
  "keywords": [
    "websocket",
    "redis",
    "firebase",
    "leaf",
    "taxi",
    "location"
  ],
  "author": "LEAF Team",
  "license": "ISC",
  "dependencies": {
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/exporter-jaeger": "^2.3.0",
    "@opentelemetry/exporter-otlp-http": "^0.26.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.208.0",
    "@opentelemetry/exporter-trace-otlp-proto": "^0.208.0",
    "@opentelemetry/instrumentation": "^0.208.0",
    "@opentelemetry/resources": "^2.3.0",
    "@opentelemetry/sdk-node": "^0.208.0",
    "@opentelemetry/semantic-conventions": "^1.38.0",
    "@socket.io/redis-adapter": "^8.3.0",
    "@turf/boolean-point-in-polygon": "^7.3.4",
    "@turf/helpers": "^7.3.4",
    "apollo-server-core": "^3.13.0",
    "apollo-server-express": "^3.13.0",
    "bcryptjs": "^3.0.2",
    "cors": "^2.8.5",
    "dataloader": "^2.2.3",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^8.0.1",
    "express-validator": "^7.2.1",
    "firebase-admin": "^12.7.0",
    "form-data": "^4.0.0",
    "graphql": "^16.11.0",
    "graphql-cost-analysis": "^1.0.3",
    "graphql-depth-limit": "^1.1.0",
    "graphql-subscriptions": "^3.0.0",
    "h3-js": "^4.3.0",
    "ioredis": "^5.6.1",
    "jsonwebtoken": "^9.0.2",
    "ml-matrix": "^6.12.1",
    "multer": "^1.4.5-lts.1",
    "ngeohash": "^0.6.3",
    "node-cache": "^5.1.2",
    "node-cron": "^4.2.1",
    "node-fetch": "^3.3.2",
    "pdf-parse": "^1.1.4",
    "pdfkit": "^0.17.2",
    "prom-client": "^15.1.3",
    "redis": "^4.6.10",
    "sharp": "^0.33.5",
    "socket.io": "^4.7.2",
    "tesseract.js": "^5.0.4",
    "uuid": "^13.0.0",
    "winston": "^3.17.0",
    "ws": "^8.18.3",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@graphql-tools/mock": "^9.0.25",
    "@graphql-tools/schema": "^10.0.25",
    "@graphql-tools/utils": "^10.9.1",
    "axios": "^1.13.2",
    "mongodb-memory-server": "^11.0.1",
    "nodemon": "^3.0.1",
    "pdf-poppler": "^0.2.3",
    "socket.io-client": "^4.8.3",
    "supertest": "^7.2.2"
  }
}
