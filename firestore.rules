rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Permitir leitura/escrita para usuários autenticados
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
    
    // Regras específicas para testes
    match /test_permissions/{document} {
      allow read, write: if request.auth != null;
    }
    
    // Regras específicas para viagens
    match /trips/{tripId} {
      allow read, write: if request.auth != null;
    }
    
    // Regras específicas para localizações de usuários
    match /user_locations/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }
    
    // Regras específicas para status de motoristas
    match /driver_status/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }
    
    // Regras específicas para viagens canceladas
    match /cancelled_trips/{tripId} {
      allow read, write: if request.auth != null;
    }
    
    // Regras para backups
    match /backups/{timestamp} {
      allow read, write: if request.auth != null;
    }
  }
} 
